# Assets pesados NO usados por la web (se mantienen locales, no se pushean)
# Solo se usa public/assets/hero/intro-definitivo-web.mp4 (7.2MB) + poster + pool/salon.
public/assets/hero/intro-definitivo-4k.mp4
public/assets/hero/intro-definitivo-720.mp4
public/assets/hero/intro-bochile.mp4
public/assets/hero/intro-casa.mp4
public/assets/hero/intro-casa-mobile.mp4
public/assets/hero/intro-drone.mp4
public/assets/video/
public/assets/stock/
# props/: fotos sueltas viejas sin usar quedan locales, PERO los recorridos en
# video publicados (+ su poster) SÍ van a la web. Convención: <slug>.mp4 / <slug>-poster.jpg
public/assets/props/*
!public/assets/props/*.mp4
!public/assets/props/*-poster.jpg
