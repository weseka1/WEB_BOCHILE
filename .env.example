# ─── Supabase ───────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...la-anon-key...

# Solo para el script de migración (scripts/migrate-to-supabase.cjs).
# ⚠️ NUNCA le pongas el prefijo VITE_ (no debe terminar en el frontend).
# Supabase → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...la-service-role-key...

# ─── Camila (chatbot) ─────────────────────────────────────────────────────────
# Webhook de n8n. Si no se setea, usa el valor por defecto de producción.
VITE_CAMILA_WEBHOOK=https://weseka.onrender.com/webhook/bochile-camila
